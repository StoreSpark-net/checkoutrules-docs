# Gleap API credentials
# Get your API key from: Gleap Dashboard → Project Settings → Security → API Key
GLEAP_API_KEY=your_api_key_here

# Get your Project ID from: Gleap Dashboard → Project Settings → Security
GLEAP_PROJECT_ID=your_project_id_here

# Base URL of your Mintlify docs site (used to resolve /images/... paths to absolute URLs)
# Defaults to https://docs.checkoutrules.com if not set
DOCS_BASE_URL=https://docs.checkoutrules.com

# Help center domain for post-sync verification (e.g. help.checkoutrules.com).
# If unset, derived from DOCS_BASE_URL only when hostname starts with "docs."
# Set this when DOCS_BASE_URL doesn't follow that pattern (e.g. example.com/docs).
# GLEAP_HELP_CENTER_DOMAIN=help.checkoutrules.com
